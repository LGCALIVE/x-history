{
  "manifest_version": 3,
  "name": "X History",
  "version": "1.0.0",
  "description": "Record your browsing history on X",
  "author": "Jay Liu (https://github.com/LGCALIVE)",
  "homepage_url": "https://github.com/LGCALIVE/x-history",
  "permissions": ["storage", "unlimitedStorage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.x.com/*", "*://*.twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
